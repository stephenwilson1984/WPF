<Window x:Class="TreeViewsAndValueConverters.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TreeViewsAndValueConverters"
        xmlns:vm="clr-namespace:TreeViewsAndValueConverters.Directory.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="600">

    <Window.DataContext>
        <vm:DirectoryStructureViewModel/>
    </Window.DataContext>

    <Grid>
        <TreeView x:Name="FolderView" ItemsSource="{Binding Path=Items, Mode=OneWay}">
            <TreeView.ItemContainerStyle>
                <Style TargetType="{x:Type TreeViewItem}">
                    <Setter Property="IsExpanded" Value="{Binding Path=IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.ItemContainerStyle>

            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Path=Children, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal">
                        <Image 
                            Width="20" 
                            Margin="3" 
                            Source="{Binding Path=Type, Converter={x:Static local:HeaderToImageConverter.Instance}}"/>
                        <TextBlock VerticalAlignment="Center" Text="{Binding Path=Name}"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</Window>
